# Privy Auth (user login + embedded wallet)
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"

# Hono backend base URL (required — app is a thin client and all writes go through backend)
# Production: https://backend-wealthcrypto-fund.vercel.app
NEXT_PUBLIC_API_BASE_URL="https://backend-wealthcrypto-fund.vercel.app"

# $WEALTH ERC-20 contract on Base mainnet (chainId 8453). Used for reading balances
# and as the transfer contract during redemption signing.
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# Optional: custom Base RPC. Defaults to the public Base RPC.
# Keep this under NEXT_PUBLIC_ because wagmi runs in the browser — use an
# allow-listed key (domain restrictions, throttled) in production.
# NEXT_PUBLIC_ALCHEMY_RPC_URL="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"

# Public app URL (used in emails, share links, metadata)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
