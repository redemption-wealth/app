# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Privy Auth (User login - email only)
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# Blockchain (Base network)
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS="0x..."
NEXT_PUBLIC_TREASURY_WALLET_ADDRESS="0x..."
NEXT_PUBLIC_ALCHEMY_API_KEY="your-alchemy-api-key"
ALCHEMY_WEBHOOK_SIGNING_KEY="your-webhook-signing-key"

# Price Feed
NEXT_PUBLIC_COINGECKO_API_KEY="your-coingecko-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BACK_OFFICE_URL="http://localhost:5173"
