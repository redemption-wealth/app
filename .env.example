# Privy Auth (user login + embedded wallet)
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"

# Hono backend base URL (required — app is a thin client and all writes go through backend)
# Production: https://backend-wealthcrypto-fund.vercel.app
NEXT_PUBLIC_API_BASE_URL="https://backend-wealthcrypto-fund.vercel.app"

# Network: "mainnet" or "sepolia"
NEXT_PUBLIC_CHAIN="sepolia"

# $WEALTH ERC-20 contract address for the selected chain.
# Mainnet:  0xafa702c0A2a3a0Cf1bD09435DB61C913cCDe8546
# Sepolia:  0x3e8c88aA176bE71Ea8124ed278a6347A85d46353
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS="0x3e8c88aA176bE71Ea8124ed278a6347A85d46353"

# Alchemy RPC URL (must match NEXT_PUBLIC_CHAIN).
# Mainnet: https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"

# Public app URL (used in emails, share links, metadata)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
