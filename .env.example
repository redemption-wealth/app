# Privy Auth (user login + embedded wallet)
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"

# Hono backend base URL (required — app is a thin client)
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# Blockchain (Base mainnet, chain 8453)
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
NEXT_PUBLIC_TREASURY_WALLET_ADDRESS="0x0000000000000000000000000000000000000000"

# Optional: custom Base RPC endpoint (e.g. Alchemy). Defaults to public Base RPC.
# NEXT_PUBLIC_ALCHEMY_RPC_URL="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
